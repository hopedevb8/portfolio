ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=scrypt:replace-with-generated-hash
ADMIN_ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
API_HOST=127.0.0.1
API_PORT=3001
# For production on a mounted volume, e.g. /data/portfolio.sqlite
# DATABASE_FILE_PATH=/data/portfolio.sqlite
ADMIN_ACCESS_TOKEN_TTL_MS=900000
ADMIN_REFRESH_TOKEN_TTL_MS=604800000
ADMIN_LOGIN_ATTEMPT_WINDOW_MS=600000
ADMIN_LOGIN_ATTEMPT_MAX=5
ADMIN_LOGIN_BLOCK_MS=900000
# Allowed frontend origins for authenticated admin requests.
# For GitHub Pages production, include your published origin, e.g.
# ADMIN_ALLOWED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000,https://your-user.github.io
ADMIN_ALLOWED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000
# Cross-origin production admin auth:
ADMIN_REFRESH_COOKIE_SAME_SITE=None
ADMIN_REFRESH_COOKIE_SECURE=true
# Optional: set only if you explicitly need a cookie domain override.
# ADMIN_REFRESH_COOKIE_DOMAIN=api.your-domain.com
